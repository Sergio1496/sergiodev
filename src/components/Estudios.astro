---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const t = useTranslations(getLangFromUrl(Astro.url));
---

<section class="flex justify-center items-center py-20 relative">
  <div class="reveal max-w-2xl text-center">
    <h2
      class="text-4xl md:text-5xl lg:text-6xl text-white font-josefin font-bold mb-4"
    >
      {t("studies.degree")}
    </h2>
    <img
      src="/images/eiplogo.webp"
      alt="EIP International Business School"
      width="2488"
      height="554"
      class="mx-auto mb-4 w-[200px] h-auto"
      loading="lazy"
      decoding="async"
    />
    <p class="text-lg text-gray-400 font-mulish mb-2">
      EIP International Business School
    </p>
    <p class="text-md text-gray-400 font-mulish mb-6">2022 - 2024</p>
    <p class="text-gray-300 font-mulish">
      {t("studies.body")}
    </p>
  </div>
</section>
