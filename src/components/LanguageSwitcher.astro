---
import { getLangFromUrl, useTranslations, localizePath, locales, languages } from "../i18n/utils";

const current = getLangFromUrl(Astro.url);
const t = useTranslations(current);
const path = Astro.url.pathname;
---

<div class="relative" id="lang-switcher">
  <button
    id="lang-toggle"
    type="button"
    class="flex items-center gap-1.5 px-2.5 py-2 rounded-lg bg-white/5 border border-white/10 text-white hover:bg-white/10 transition-colors duration-200 text-sm font-josefin font-semibold"
    aria-haspopup="true"
    aria-expanded="false"
    aria-label={t("lang.label")}
  >
    <svg class="w-4 h-4 opacity-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
      <circle cx="12" cy="12" r="9" stroke-width="1.8" />
      <path stroke-width="1.8" stroke-linecap="round" d="M3 12h18M12 3c2.5 2.7 2.5 15.3 0 18M12 3c-2.5 2.7-2.5 15.3 0 18" />
    </svg>
    <span class="uppercase">{current}</span>
    <svg
      id="lang-chevron"
      class="w-3 h-3 opacity-70 transition-transform duration-200"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      aria-hidden="true"
    >
      <path stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" />
    </svg>
  </button>

  <ul
    id="lang-menu"
    class="absolute right-0 mt-2 w-40 py-1 rounded-xl bg-gray-900 border border-white/10 shadow-2xl z-50 origin-top-right transition-all duration-200 ease-out opacity-0 invisible scale-95 -translate-y-1"
    role="menu"
    aria-label={t("lang.label")}
  >
    {
      locales.map((code) => (
        <li role="none">
          <a
            role="menuitem"
            href={localizePath(path, code)}
            hreflang={code}
            aria-current={code === current ? "true" : undefined}
            class={
              code === current
                ? "flex items-center gap-2 px-4 py-2.5 text-sm text-pink-500 font-semibold"
                : "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-300 hover:text-white hover:bg-white/5 transition-colors duration-200"
            }
          >
            <span class="w-3.5 inline-flex justify-center text-pink-500">
              {code === current ? "✓" : ""}
            </span>
            {languages[code]}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script is:inline>
  // Anima el despliegue (fundido + escala) en lugar de mostrar/ocultar seco.
  function langSetOpen(open) {
    const toggle = document.getElementById("lang-toggle");
    const menu = document.getElementById("lang-menu");
    const chevron = document.getElementById("lang-chevron");
    if (!toggle || !menu) return;
    const closed = ["opacity-0", "invisible", "scale-95", "-translate-y-1"];
    if (open) {
      menu.classList.remove(...closed);
      menu.classList.add("opacity-100");
    } else {
      menu.classList.remove("opacity-100");
      menu.classList.add(...closed);
    }
    toggle.setAttribute("aria-expanded", open ? "true" : "false");
    if (chevron) chevron.classList.toggle("rotate-180", open);
  }

  function initLangSwitcher() {
    const toggle = document.getElementById("lang-toggle");
    if (!toggle || toggle.dataset.bound === "true") return;
    toggle.dataset.bound = "true";
    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      langSetOpen(toggle.getAttribute("aria-expanded") !== "true");
    });
  }

  // Listeners globales (una sola vez): cerrar al hacer clic fuera o con Escape.
  if (!window.__langGlobalBound) {
    window.__langGlobalBound = true;
    document.addEventListener("click", (e) => {
      const toggle = document.getElementById("lang-toggle");
      const menu = document.getElementById("lang-menu");
      if (menu && toggle && !menu.contains(e.target) && !toggle.contains(e.target)) {
        langSetOpen(false);
      }
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") langSetOpen(false);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLangSwitcher);
  } else {
    initLangSwitcher();
  }
  document.addEventListener("astro:after-swap", initLangSwitcher);
  document.addEventListener("astro:page-load", initLangSwitcher);
</script>
