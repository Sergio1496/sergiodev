---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const RECAPTCHA_SITE_KEY = import.meta.env.RECAPTCHA_SITE_KEY;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const errorMessages = {
  campos: t("contact.err.campos"),
  envio: t("contact.err.envio"),
  generic: t("contact.err.generic"),
};
---

<section class="flex flex-col relative" aria-label="Contacto">
  <div
    id="contact"
    class="container items-center mx-auto font-josefin font-medium pt-10 px-5 sm:px-10 md:px-10 lg:px-44 delay-[300ms] duration-[600ms] animate-fade-in"
    transition:animate="fade"
  >
    <h2
      class="text-white text-center text-4xl md:text-5xl lg:text-6xl font-josefin font-bold"
    >
      {t("contact.title")}
    </h2>
    <div class="pt-5 md:pt-10">
      <div class="p-4 md:p-8">
        <p class="pb-2">{t("contact.intro")}</p>
        <div
          id="contactError"
          role="alert"
          hidden
          class="flex items-center gap-3 mb-2 px-4 py-3 rounded-md border border-red-500/40 bg-red-500/10 text-red-200 text-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            class="flex-shrink-0"
          >
            <path
              fill="currentColor"
              d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10s10-4.48 10-10S17.52 2 12 2m1 15h-2v-2h2zm0-4h-2V7h2z"
            />
          </svg>
          <span id="contactErrorText"></span>
        </div>
        <form
          class="flex flex-col items-center"
          action="/api/send-email"
          method="POST"
          id="contactForm"
        >
          <div class="md:w-3/4 lg:w-2/3">
            <div class="flex flex-col md:flex-row">
              <input
                id="send-email__nameOf"
                type="text"
                name="nameOf"
                required
                class="my-2 py-2 px-4 rounded-md bg-zinc-800 text-white w-full md:w-1/2 md:mr-2 outline-none focus:ring-2 focus:ring-blue-600"
                placeholder={t("contact.name")}
              />
              <input
                id="send-email__recipient"
                name="recipient"
                type="email"
                required
                class="my-2 py-2 px-4 rounded-md bg-zinc-800 text-white w-full md:w-1/2 md:ml-2 outline-none focus:ring-2 focus:ring-blue-600"
                placeholder={t("contact.email")}
              />
            </div>
            <input
              id="send-email__subject"
              name="subject"
              type="text"
              required
              placeholder={t("contact.subject")}
              class="my-2 py-2 px-4 rounded-md bg-zinc-800 text-white w-full outline-none focus:ring-2 focus:ring-blue-600"
            />
            <textarea
              id="send-email__message"
              rows="5"
              placeholder={t("contact.message")}
              name="message"
              required
              class="my-2 py-2 px-4 rounded-md bg-zinc-800 text-white w-full outline-none focus:ring-2 focus:ring-blue-600"
            ></textarea>
            <!-- Campo oculto para almacenar el token de reCAPTCHA -->
            <input
              type="hidden"
              name="g-recaptcha-response"
              id="recaptchaResponse"
            />
            <!-- Idioma actual, para redirigir al locale correcto tras enviar -->
            <input type="hidden" name="locale" value={lang} />
          </div>
          <div class="relative inline-flex group rounded-xl border-beam mx-5 my-5">
            <button
              type="submit"
              id="submitBtn"
              class="relative inline-flex items-center justify-center w-full px-8 py-4 text-lg font-josefin font-medium text-white transition-all duration-200 bg-gray-900 hover:bg-gray-800 font-pj rounded-[10px] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900"
            >
              {t("contact.send")}

              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                class="ml-2"
                ><path
                  fill="currentColor"
                  d="M3 20V4l19 8l-19 8Zm2-3l11.85-5L5 7v3.5l6 1.5l-6 1.5V17Zm0 0V7v10Z"
                ></path></svg
              >
            </button>
          </div>
          <!--           <p class="text-sm text-gray-400 text-center mt-2">
            Este sitio está protegido por reCAPTCHA y aplican la <a
              href="https://policies.google.com/privacy"
              class="text-blue-400 hover:underline">Política de Privacidad</a
            > y los <a
              href="https://policies.google.com/terms"
              class="text-blue-400 hover:underline">Términos de Servicio</a
            > de Google.
          </p> -->
        </form>
      </div>
    </div>
  </div>
</section>

<!-- Script para cargar reCAPTCHA v3 -->
<script is:inline define:vars={{ RECAPTCHA_SITE_KEY, errorMessages }}>
  // Cargar la API de reCAPTCHA v3 (una sola vez, solo si hay site key)
  function loadRecaptcha() {
    if (!RECAPTCHA_SITE_KEY) return;
    if (document.getElementById("recaptcha-script")) return;
    const script = document.createElement("script");
    script.id = "recaptcha-script";
    script.src = `https://www.google.com/recaptcha/api.js?render=${RECAPTCHA_SITE_KEY}`;
    document.head.appendChild(script);
  }

  function initContactForm() {
    loadRecaptcha();

    const form = document.getElementById("contactForm");
    if (!form || form.dataset.bound === "true") return;
    form.dataset.bound = "true";

    form.addEventListener("submit", function (event) {
      // Sin reCAPTCHA disponible: dejamos el envío nativo del formulario.
      if (!RECAPTCHA_SITE_KEY || typeof grecaptcha === "undefined") return;

      event.preventDefault();
      try {
        grecaptcha.ready(function () {
          grecaptcha
            .execute(RECAPTCHA_SITE_KEY, { action: "submit" })
            .then(function (token) {
              const field = document.getElementById("recaptchaResponse");
              if (field) field.value = token;
              form.submit();
            })
            // Si reCAPTCHA falla, no bloqueamos al usuario: enviamos igual.
            .catch(function () {
              form.submit();
            });
        });
      } catch (e) {
        form.submit();
      }
    });
  }

  // Muestra el aviso de error que llega como ?error= tras la redirección del
  // endpoint. Se ejecuta en cliente para que la página pueda servirse estática.
  function showFormError() {
    const url = new URL(window.location.href);
    const code = url.searchParams.get("error");
    if (!code) return;

    const box = document.getElementById("contactError");
    const text = document.getElementById("contactErrorText");
    if (box && text) {
      text.textContent = errorMessages[code] ?? errorMessages.generic;
      box.hidden = false;
    }

    // De un solo uso: quitamos ?error= (conservando el #contact) para que un
    // refresco no lo muestre de nuevo con el formulario ya vacío.
    url.searchParams.delete("error");
    window.history.replaceState(
      {},
      "",
      url.pathname + url.search + url.hash
    );
  }

  function initContact() {
    initContactForm();
    showFormError();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initContact);
  } else {
    initContact();
  }
  document.addEventListener("astro:after-swap", initContact);
  document.addEventListener("astro:page-load", initContact);
</script>
