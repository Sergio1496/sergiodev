---
import { fade } from "astro:transitions";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const t = useTranslations(getLangFromUrl(Astro.url));
---

<section
  class="flex flex-col justify-center items-center pt-24 pb-12 relative"
  transition:animate={fade({ duration: "0.3s" })}
>
  <h1
    id="nombre"
    class="z-1 pb-2 leading-none sm:leading-tight lg:leading-none tracking-tight text-center bg-clip-text text-transparent bg-gradient-to-r from-pink-500 to-violet-500 font-josefin font-bold text-6xl sm:text-5xl md:text-6xl lg:text-6xl delay-[100ms] duration-[500ms]"
  >
    Sergio Expósito
  </h1>

  <h2
    id="role"
    class="text-xl sm:text-2xl md:text-2xl lg:text-2xl sm:leading-tight lg:leading-relaxed tracking-tight text-center font-josefin font-medium delay-[100ms] duration-[500ms]"
  >
    {t("hero.role")}
  </h2>
</section>
