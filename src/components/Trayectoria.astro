---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { career } from "../i18n/career";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const jobs = career[lang];
---

<section
  class="flex text-left sm:py-5 md:py-20 lg:py-20 relative"
  aria-label={t("career.title")}
>
  <div
    class="container font-josefin font-medium mx-auto px-4 py-8 delay-[100ms] duration-[400ms]"
  >
    <h2
      class="reveal text-white text-center pb-10 text-4xl md:text-5xl lg:text-6xl font-josefin font-bold"
    >
      {t("career.title")}
    </h2>

    <div class="max-w-2xl mx-auto">
      <ol class="relative border-l border-gray-700">
        {
          jobs.map((job, i) => (
            <li class="reveal mb-10 ml-4" style={`transition-delay: ${i * 0.08}s`}>
              <div class="absolute w-3 h-3 bg-gray-700 rounded-full -left-1.5 border border-gray-900" />
              <time class="mb-1 text-sm font-mulish leading-none text-gray-300">
                {job.date}
              </time>
              <h3 class="text-xl font-josefin font-bold text-white">
                {job.role}
              </h3>
              <p class="mb-4 text-base text-gray-400 font-mulish text-pretty">
                {job.lines.map((line, i) => (
                  <Fragment>
                    {line}
                    {i < job.lines.length - 1 && <br />}
                  </Fragment>
                ))}
              </p>

              {job.sub && (
                <ol class="ml-4 border-l-2 border-gray-700">
                  {job.sub.map((subJob) => (
                    <li class="mb-4 ml-4">
                      <time class="mb-1 text-sm font-mulish leading-none text-gray-300">
                        {subJob.date}
                      </time>
                      <h4 class="text-xl font-josefin font-bold text-white">
                        {subJob.role}
                      </h4>
                      <p class="mb-4 text-base font-mulish text-gray-400">
                        {subJob.lines.map((line, i) => (
                          <Fragment>
                            {line}
                            {i < subJob.lines.length - 1 && <br />}
                          </Fragment>
                        ))}
                      </p>
                    </li>
                  ))}
                </ol>
              )}
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
