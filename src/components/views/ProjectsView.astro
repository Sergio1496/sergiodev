---
import { getCollection } from "astro:content";
import { getLangFromUrl, useTranslations, localizePath } from "../../i18n/utils";
import { getProjectText } from "../../i18n/projects";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projectEntries = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);

// Mapa proyecto → slug del artículo relacionado en el idioma actual.
const blogEntries = await getCollection("blog");
const projectRelatedEntries = new Map(
  blogEntries
    .filter((entry) => entry.id.startsWith(`${lang}/`) && entry.data.projectRelated)
    .map((entry) => [entry.data.projectRelated, entry.id.slice(lang.length + 1)])
);
---

<div class="min-h-screen text-neutral-100 py-16 relative z-10">
  <div class="container mx-auto px-4 max-w-6xl">
    <h1 class="text-5xl font-bold mb-12 tracking-tight">{t("projects.title")}</h1>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        projectEntries.map((project, index) => {
          const blogSlug = projectRelatedEntries.get(project.data.title);
          const text = getProjectText(project.id, lang, {
            title: project.data.title,
            description: project.data.description,
          });

          return (
            <article
              class="card-enter group overflow-hidden rounded-xl bg-white/[0.03] border border-white/8 hover:border-white/20 transition-colors duration-300 flex flex-col"
              style={`animation-delay: ${index * 80}ms`}
            >
              {/* Imagen */}
              <div class="relative overflow-hidden flex-shrink-0">
                <img
                  src={project.data.image}
                  alt={text.title}
                  class="w-full h-36 object-cover"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute top-3 right-3 bg-black/60 backdrop-blur-sm rounded-lg px-2.5 py-1 pointer-events-none">
                  <span class="text-[11px] font-bold text-white">{project.data.fecha}</span>
                  <span class="text-[11px] text-white/50 ml-1.5">{project.data.framework}</span>
                </div>
              </div>

              {/* Contenido */}
              <div class="p-4 flex-grow flex flex-col">
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {project.data.skills.map((skill) => (
                    <span class="px-2 py-0.5 text-[11px] font-medium text-gray-400 bg-white/5 rounded-md">
                      {skill}
                    </span>
                  ))}
                </div>

                <h2 class="text-base font-bold text-white mb-2 leading-snug">
                  {text.title}
                </h2>

                <p class="text-gray-400 text-sm leading-relaxed mb-4 flex-grow line-clamp-3">
                  {text.description}
                </p>

                {/* Footer */}
                <div class="flex items-center justify-between pt-3 border-t border-white/8">
                  <div class="flex items-center gap-3">
                    {blogSlug && (
                      <a
                        href={localizePath(`/blog/${blogSlug}`, lang)}
                        class="flex items-center gap-1.5 text-xs text-gray-400 hover:text-white transition-colors duration-200"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24">
                          <path fill="currentColor" d="M5 21q-.825 0-1.412-.587T3 19V5q0-.825.588-1.412T5 3h14q.825 0 1.413.588T21 5v14q0 .825-.587 1.413T19 21zm2-4h7v-2H7zm0-4h10v-2H7zm0-4h10V7H7z" />
                        </svg>
                        <span class="font-medium">{t("projects.article")}</span>
                      </a>
                    )}

                    {project.data.empresa && (
                      <a
                        href={project.data.empresaLink}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-center gap-1.5 text-xs text-gray-400 hover:text-white transition-colors duration-200"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24">
                          <path fill="currentColor" d="M4 21q-.825 0-1.412-.587T2 19V8q0-.825.588-1.412T4 6h4V4q0-.825.588-1.412T10 2h4q.825 0 1.413.588T16 4v2h4q.825 0 1.413.588T22 8v11q0 .825-.587 1.413T20 21zm6-15h4V4h-4z" />
                        </svg>
                        <span class="font-medium">{project.data.empresa}</span>
                      </a>
                    )}
                  </div>

                  {project.data.link && (
                    <a
                      href={project.data.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center justify-center w-8 h-8 rounded-lg bg-white/5 text-white/60 hover:bg-white/10 hover:text-white transition-colors duration-200"
                      title={project.data.link.includes("play.google.com") ? t("projects.viewPlay") : t("projects.viewProject")}
                    >
                      {project.data.link.includes("play.google.com") ? (
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z" />
                        </svg>
                      ) : (
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      )}
                    </a>
                  )}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</div>

<style>
  @keyframes cardEnter {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.98);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0px);
    }
  }

  .card-enter {
    opacity: 0;
    animation: cardEnter 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
