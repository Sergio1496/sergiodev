---
import { getCollection } from "astro:content";
import { getLangFromUrl, useTranslations, localizePath } from "../../i18n/utils";
import { dateLocale } from "../../i18n/ui";

function readingTime(text: string | undefined): string {
  if (!text) return "1 min";
  const words = text.trim().split(/\s+/).length;
  const minutes = Math.max(1, Math.round(words / 200));
  return `${minutes} min`;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const posts = (await getCollection("blog"))
  .filter((entry) => entry.id.startsWith(`${lang}/`))
  .map((entry) => ({ entry, slug: entry.id.slice(lang.length + 1) }))
  .sort((a, b) => b.entry.data.pubDate.valueOf() - a.entry.data.pubDate.valueOf());
---

<div class="min-h-screen text-neutral-100 py-16 animate-fade-in relative z-10">
  <div class="container mx-auto px-4 max-w-6xl">
    <h1 class="text-5xl font-bold mb-16 tracking-tight">{t("blog.title")}</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 fade-in auto-rows-fr">
      {
        posts.map(({ entry: post, slug }) => (
          <article class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-white/5 to-white/[0.02] backdrop-blur-sm border border-white/10 hover:border-white/20 transition-all duration-500 hover:scale-[1.005] hover:shadow-xl hover:shadow-black/15 flex flex-col">
            <a href={localizePath(`/blog/${slug}`, lang)} class="h-full flex flex-col">
              <div class="relative overflow-hidden bg-gradient-to-br from-gray-800 to-gray-900 flex-shrink-0">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-auto object-cover transition-all duration-500 group-hover:scale-102 group-hover:brightness-105 opacity-60"
                  style="min-height: 200px; max-height: 350px; object-fit: cover;"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent opacity-50 group-hover:opacity-30 transition-opacity duration-500" />
                <div class="absolute top-6 right-6 backdrop-blur-md bg-black/30 border border-white/20 rounded-2xl px-4 py-2 transform group-hover:-translate-y-0.5 transition-all duration-400">
                  <div class="text-xs font-bold text-white tracking-wider">
                    {new Date(post.data.pubDate).toLocaleDateString(dateLocale[lang], {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </div>
                  <div class="text-xs text-white/70 font-medium">
                    {readingTime(post.body)} {t("reading.suffix")}
                  </div>
                </div>
                <div class="absolute top-6 left-6 w-12 h-12 rounded-2xl bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center group-hover:bg-white/15 transition-all duration-400 group-hover:rotate-6">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                  </svg>
                </div>
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/3 to-transparent transform -skew-x-12 -translate-x-full group-hover:translate-x-full transition-transform duration-1200 ease-out" />
                <div class="absolute inset-0 bg-gradient-to-br from-transparent to-black/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
              </div>

              <div class="relative p-6 lg:p-8 group-hover:translate-y-[-1px] transition-transform duration-400 flex-grow flex flex-col">
                {post.data.tags && (
                  <div class="flex flex-wrap gap-2 mb-4">
                    {post.data.tags.map((tag, tagIndex) => (
                      <span
                        class="relative px-3 py-1.5 text-xs font-semibold text-gray-300 bg-white/5 border border-white/10 rounded-full backdrop-blur-sm group-hover:bg-white/8 group-hover:border-white/15 transition-all duration-300"
                        style={`animation-delay: ${tagIndex * 100}ms`}
                      >
                        #{tag}
                        <div class="absolute inset-0 rounded-full bg-gradient-to-r from-transparent via-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                      </span>
                    ))}
                  </div>
                )}

                <h2 class="text-xl lg:text-2xl xl:text-3xl font-bold text-white mb-3 leading-tight group-hover:tracking-wider transition-all duration-400">
                  {post.data.title}
                </h2>

                <p class="text-gray-300 text-sm lg:text-base leading-relaxed mb-6 flex-grow group-hover:text-gray-200 transition-colors duration-500">
                  {post.data.description}
                </p>

                <div class="flex items-center justify-between pt-6 border-t border-white/10 group-hover:border-white/15 transition-colors duration-500">
                  <div class="flex items-center space-x-4">
                    <div class="flex items-center space-x-2 text-sm text-gray-400 group-hover:text-white transition-colors duration-300">
                      <div class="w-6 h-6 rounded-full bg-gradient-to-r from-blue-600 to-blue-700 flex items-center justify-center">
                        <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3M19 19H5V5H19V19M17 17H7V15H17V17M17 13H7V11H17V13M17 9H7V7H17V9Z" />
                        </svg>
                      </div>
                      <span class="font-medium">{t("blog.readArticle")}</span>
                    </div>
                  </div>

                  <div class="group/link relative flex items-center justify-center w-12 h-12 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-sm hover:bg-white/10 hover:border-white/20 transition-all duration-300 hover:scale-105 hover:-translate-y-0.5">
                    <svg class="w-5 h-5 text-white/70 group-hover/link:text-white transform transition-all duration-250 group-hover/link:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                    <div class="absolute inset-0 rounded-2xl bg-gradient-to-r from-white/10 to-white/5 opacity-0 group-hover/link:opacity-100 transition-opacity duration-500" />
                  </div>
                </div>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</div>
