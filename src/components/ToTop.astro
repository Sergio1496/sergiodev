<div class="fixed bottom-0 right-0 p-4 z-50">
  <button
    aria-label="Volver arriba"
    class="bg-white/10 backdrop-blur-sm border border-white/20 text-white rounded-full w-12 h-12 mr-2 mb-10 sm:mr-5 md:mr-5 lg:mr-5 flex items-center justify-center hover:bg-white/20 transition-all duration-300 opacity-0 pointer-events-none"
    id="bckbtn"
    type="button"
    title="Volver arriba"
  >
    <svg
      class="w-5 h-5"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
    </svg>
  </button>
</div>

<script is:inline>
  function initBackToTop() {
    const backTopButton = document.getElementById("bckbtn");

    if (!backTopButton) return;

    // Función para manejar el click
    function scrollToTop() {
      window.scrollTo({
        top: 0,
        behavior: "smooth",
      });
    }

    // Función para mostrar/ocultar el botón
    function toggleButton() {
      if (window.scrollY > 200) {
        backTopButton.style.opacity = "1";
        backTopButton.style.pointerEvents = "auto";
        backTopButton.style.transform = "translateY(0)";
      } else {
        backTopButton.style.opacity = "0";
        backTopButton.style.pointerEvents = "none";
        backTopButton.style.transform = "translateY(10px)";
      }
    }

    // El botón se reemplaza en cada navegación, así que basta con añadirle
    // el listener de click al nodo actual.
    backTopButton.addEventListener("click", scrollToTop);

    // window persiste entre navegaciones (View Transitions): removemos el
    // handler de scroll anterior por referencia para no acumular listeners.
    if (window.__toTopScrollHandler) {
      window.removeEventListener("scroll", window.__toTopScrollHandler);
    }
    window.__toTopScrollHandler = toggleButton;
    window.addEventListener("scroll", toggleButton, { passive: true });

    // Verificar posición inicial
    toggleButton();
  }

  // Inicializar cuando el DOM esté listo
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBackToTop);
  } else {
    initBackToTop();
  }

  // Reinicializar después de las transiciones de Astro
  document.addEventListener("astro:after-swap", initBackToTop);
  document.addEventListener("astro:page-load", initBackToTop);
</script>

<style>
  #bckbtn {
    transition:
      opacity 0.3s ease-in-out,
      transform 0.3s ease-in-out,
      background-color 0.3s ease-in-out;
  }

  #bckbtn:hover {
    transform: translateY(-2px) !important;
  }
</style>
