---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const t = useTranslations(getLangFromUrl(Astro.url));
---

<section
  class="flex justify-center delay-[300ms] duration-[500ms] sm:py-5 md:py-20 lg:py-0 relative"
>
  <div
    class="flex flex-col sm:flex-col md:flex-col lg:flex-row justify-between items-center"
  >
    <div class="relative inline-flex group mx-5">
      <a
        href="#contact"
        class="relative inline-flex items-center justify-center px-8 py-4 text-lg shadow-md font-josefin font-medium text-white transition-all duration-200 bg-zinc-800 hover:bg-zinc-900 font-pj rounded-xl focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900"
        role="button"
        aria-label={t("btn.contact")}
        >{t("btn.contact")}
      </a>
    </div>
    <div
      class="relative inline-flex group rounded-xl border-beam mx-5 my-10 sm:my-10 md:my-10 lg:my-10"
    >
      <a
        href="/cv.pdf"
        style={{ boxShadow: "0 10px 15px rgba(0, 0, 0, 0.5)" }}
        class="relative inline-flex items-center justify-center w-full px-8 py-4 text-lg font-josefin font-medium text-white transition-all duration-200 bg-zinc-800 hover:bg-zinc-900 font-pj rounded-[10px] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900"
        role="button"
        aria-label={t("btn.cv")}
        download
        >{t("btn.cv")}

        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="ml-2"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          fill="none"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
            d="M11 7h-5a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-5"
          ></path><line x1="10" y1="14" x2="20" y2="4"></line><polyline
            points="15 4 20 4 20 9"></polyline></svg
        >
      </a>
    </div>
  </div>
</section>
