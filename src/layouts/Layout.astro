---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import ToTop from "../components/ToTop.astro";
import "../styles/global.css";
import { Tooltips } from "astro-tooltips";
import { getLangFromUrl, useTranslations, localizePath, locales } from "../i18n/utils";
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const SITE_URL = "https://sergioem.dev";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { title, description = t("meta.description"), image = "/images/og-default.webp" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, SITE_URL);
const ogImageURL = new URL(image, SITE_URL);

const ogLocales: Record<string, string> = {
  es: "es_ES",
  en: "en_US",
  fr: "fr_FR",
  it: "it_IT",
};

// Alternativas hreflang para SEO multi-idioma (misma página en cada locale).
const alternates = locales.map((code) => ({
  code,
  href: new URL(localizePath(Astro.url.pathname, code), SITE_URL).toString(),
}));

// Datos estructurados (rich results en Google).
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Sergio Expósito Martínez",
  url: SITE_URL,
  jobTitle: "Desarrollador Fullstack de aplicaciones móviles",
  email: "sergioexpositodev@gmail.com",
  sameAs: [
    "https://github.com/Sergio1496",
    "https://www.linkedin.com/in/sergioexposito",
  ],
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL} />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.code} href={alt.href} />
    ))}
    <link
      rel="alternate"
      hreflang="x-default"
      href={alternates.find((a) => a.code === "es")?.href}
    />
    <meta name="generator" content={Astro.generator} />

    <!-- Preload de fuentes críticas (encabezados + cuerpo) -->
    <link
      rel="preload"
      href="/fonts/Josefin/JosefinSans-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/Mulish/Mulish-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Datos estructurados -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />


    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content={ogLocales[lang]} />
    <meta property="og:site_name" content="Sergio Expósito" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <Tooltips
      interactive={false}
      delay={[15, 50]}
      animation="fade"
      placement="top"
    />

    <title>{title}</title>
  </head>

  <body
    class="relative overflow-hidden scrollbar scrollbar-thumb-zinc-800 scrollbar-track-transparent scrollbar-thumb-rounded-full scrollbar-track-rounded-full"
  >
    <!-- Fondo elegante simplificado -->
    <div class="fixed inset-0 z-0">
      <!-- Fondo base con degradado suave -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-slate-950 via-gray-900 to-neutral-950"
      >
      </div>

      <!-- Efectos de luz ambiental sutiles -->
      <div
        class="absolute top-1/4 left-1/4 w-96 h-96 bg-blue-600/5 rounded-full blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-purple-600/5 rounded-full blur-3xl"
      >
      </div>
      <div
        class="absolute top-3/4 left-3/4 w-72 h-72 bg-pink-600/4 rounded-full blur-3xl"
      >
      </div>

      <!-- Overlay final para consistencia -->
      <div class="absolute inset-0 bg-black/10"></div>
    </div>

    <!-- Contenido principal -->
    <div class="relative z-10">
      <Header />
      <slot />
      <Footer />
      <ToTop />
    </div>
    <style is:global>
      img {
        content-visibility: auto;
      }

      :root {
        --accent: 136, 58, 234;
        --accent-light: 224, 204, 250;
        --accent-dark: 49, 10, 101;
        --accent-gradient: linear-gradient(
          45deg,
          rgb(var(--accent)),
          rgb(var(--accent-light)) 30%,
          white 60%
        );
      }

      html {
        overflow-x: hidden;
        font-family: system-ui, sans-serif;
        background: #13151a;
        background-size: 224px;
      }

      main {
        padding: 1rem;
        color: white;
        font-size: 20px;
        line-height: 1.6;
      }

      /* Animación de Fade-In */
      @keyframes fade-in {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .animate-fade-in {
        animation: fade-in 0.6s ease-out forwards;
      }

      /* Animación Tilt (si la necesitas) */
      @keyframes tilt {
        0% {
          transform: rotate(0deg);
        }
        50% {
          transform: rotate(3deg);
        }
        100% {
          transform: rotate(0deg);
        }
      }

      .animate-tilt {
        animation: tilt 1s infinite;
      }
      .grecaptcha-badge {
        visibility: hidden !important;
      }

      /* Asegurar que el contenido tenga el z-index correcto */
      main,
      footer {
        position: relative;
        z-index: 10;
      }
      header {
        position: relative;
        z-index: 50;
      }
    </style>
  </body>
</html>
