---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import ToTop from "../components/ToTop.astro";
import "../styles/global.css";
import { Tooltips } from "astro-tooltips";
import { getLangFromUrl, useTranslations, localizePath, locales } from "../i18n/utils";
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const SITE_URL = "https://sergioem.dev";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { title, description = t("meta.description"), image = "/images/og-default.webp" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, SITE_URL);
const ogImageURL = new URL(image, SITE_URL);

const ogLocales: Record<string, string> = {
  es: "es_ES",
  en: "en_US",
  fr: "fr_FR",
  it: "it_IT",
};

// Alternativas hreflang para SEO multi-idioma (misma página en cada locale).
const alternates = locales.map((code) => ({
  code,
  href: new URL(localizePath(Astro.url.pathname, code), SITE_URL).toString(),
}));

// Datos estructurados (rich results en Google).
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Sergio Expósito Martínez",
  url: SITE_URL,
  jobTitle: "Desarrollador Fullstack de aplicaciones móviles",
  email: "sergioexpositodev@gmail.com",
  sameAs: [
    "https://github.com/Sergio1496",
    "https://www.linkedin.com/in/sergioexposito",
  ],
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    {/* Marca JS activo antes de pintar, para que los reveal partan ocultos sin parpadeo */}
    <script is:inline>document.documentElement.classList.add("js");</script>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL} />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.code} href={alt.href} />
    ))}
    <link
      rel="alternate"
      hreflang="x-default"
      href={alternates.find((a) => a.code === "es")?.href}
    />
    <meta name="generator" content={Astro.generator} />

    <!-- Preload de fuentes críticas (encabezados + cuerpo) -->
    <link
      rel="preload"
      href="/fonts/Josefin/JosefinSans-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/Mulish/Mulish-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Datos estructurados -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />


    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content={ogLocales[lang]} />
    <meta property="og:site_name" content="Sergio Expósito" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <Tooltips
      interactive={false}
      delay={[15, 50]}
      animation="fade"
      placement="top"
    />

    <title>{title}</title>
  </head>

  <body
    class="relative overflow-hidden scrollbar scrollbar-thumb-zinc-800 scrollbar-track-transparent scrollbar-thumb-rounded-full scrollbar-track-rounded-full"
  >
    <!-- Fondo elegante simplificado -->
    <div class="fixed inset-0 z-0">
      <!-- Fondo base con degradado suave -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-slate-950 via-gray-900 to-neutral-950"
      >
      </div>

      <!-- Patrón de puntos sutil con parallax -->
      <div data-parallax-dots="0.4" class="absolute inset-0 bg-dots"></div>

      <!-- Un único halo de marca (rosa/violeta) con parallax -->
      <div
        data-parallax="0.25"
        class="absolute top-[12%] left-1/2 -ml-[22rem] w-[44rem] h-[44rem] rounded-full blur-3xl"
        style="background: radial-gradient(circle, rgba(236,72,153,0.13), rgba(139,92,246,0.07) 45%, transparent 70%);"
      >
      </div>

      <!-- Overlay final para consistencia -->
      <div class="absolute inset-0 bg-black/10"></div>
    </div>

    <!-- Contenido principal -->
    <div class="relative z-10">
      <Header />
      <slot />
      <Footer />
      <ToTop />
    </div>

    {/* Reveal al hacer scroll: añade .is-visible cuando el elemento entra en viewport */}
    <script is:inline>
      function initReveal() {
        document.documentElement.classList.add("js");
        const els = document.querySelectorAll(".reveal:not(.is-visible)");
        if (!("IntersectionObserver" in window)) {
          els.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.15 }
        );
        els.forEach((el) => io.observe(el));
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initReveal);
      } else {
        initReveal();
      }
      document.addEventListener("astro:page-load", initReveal);
    </script>

    {/* Parallax de los focos de luz del fondo: cada uno se mueve a distinta velocidad */}
    <script is:inline>
      (function () {
        if (window.__bgParallax) return;
        window.__bgParallax = true;
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
        let ticking = false;
        function update() {
          ticking = false;
          const y = reduce.matches ? 0 : window.scrollY;
          document.querySelectorAll("[data-parallax]").forEach((b) => {
            const speed = parseFloat(b.getAttribute("data-parallax")) || 0;
            b.style.transform = "translate3d(0," + (y * speed).toFixed(1) + "px,0)";
          });
          const dots = document.querySelector("[data-parallax-dots]");
          if (dots) {
            const f = parseFloat(dots.getAttribute("data-parallax-dots")) || 0;
            dots.style.backgroundPositionY = (y * f).toFixed(1) + "px";
          }
        }
        function onScroll() {
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(update);
          }
        }
        window.addEventListener("scroll", onScroll, { passive: true });
        document.addEventListener("astro:page-load", update);
        update();
      })();
    </script>
    <style is:global>
      img {
        content-visibility: auto;
      }

      :root {
        --accent: 136, 58, 234;
        --accent-light: 224, 204, 250;
        --accent-dark: 49, 10, 101;
        --accent-gradient: linear-gradient(
          45deg,
          rgb(var(--accent)),
          rgb(var(--accent-light)) 30%,
          white 60%
        );
      }

      html {
        overflow-x: hidden;
        font-family: system-ui, sans-serif;
        background: #13151a;
        background-size: 224px;
      }

      main {
        padding: 1rem;
        color: white;
        font-size: 20px;
        line-height: 1.6;
      }

      /* Animación de Fade-In */
      @keyframes fade-in {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .animate-fade-in {
        animation: fade-in 0.6s ease-out forwards;
      }

      /* Animación Tilt (si la necesitas) */
      @keyframes tilt {
        0% {
          transform: rotate(0deg);
        }
        50% {
          transform: rotate(3deg);
        }
        100% {
          transform: rotate(0deg);
        }
      }

      .animate-tilt {
        animation: tilt 1s infinite;
      }
      .grecaptcha-badge {
        visibility: hidden !important;
      }

      /* Asegurar que el contenido tenga el z-index correcto */
      main,
      footer {
        position: relative;
        z-index: 10;
      }
      header {
        position: relative;
        z-index: 50;
      }
    </style>
  </body>
</html>
