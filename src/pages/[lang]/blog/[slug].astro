---
import Layout from "../../../layouts/Layout.astro";
import BlogPostView from "../../../components/views/BlogPostView.astro";
import { getCollection } from "astro:content";
import { pageTransition } from "../../../transitions";

export const prerender = true;

export async function getStaticPaths() {
  const all = await getCollection("blog");
  return all
    .filter((entry) => !entry.id.startsWith("es/"))
    .map((entry) => {
      const [code, ...rest] = entry.id.split("/");
      return {
        params: { lang: code, slug: rest.join("/") },
        props: { post: entry },
      };
    });
}

const { post } = Astro.props;
---

<Layout
  title={`${post.data.title} | Sergio Expósito Martínez`}
  description={post.data.description}
  image={post.data.image}
  transition:animate={pageTransition}
>
  <BlogPostView post={post} />
</Layout>
